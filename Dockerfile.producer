FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir kafka-python==2.0.2 websocket-client==1.8.0 requests==2.32.3

COPY normalizer.py order_book.py resync.py partitioning.py ./
COPY producer_stream.py producer_binance.py producer_kraken.py ./

ENV PYTHONUNBUFFERED=1

# Producer script is chosen at runtime via docker-compose command:
CMD ["python", "producer_stream.py"]
