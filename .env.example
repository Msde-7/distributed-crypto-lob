# Copy to .env and fill in for your machine. .env is gitignored.

# Local install paths (Windows examples shown)
JAVA_HOME=C:\Program Files\Microsoft\jdk-17.0.18.8-hotspot
KAFKA_HOME=C:\tools\kafka_2.13-3.9.0
SPARK_HOME=C:\tools\spark-3.5.8-bin-hadoop3
HADOOP_HOME=C:\tools\hadoop

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=lob-events
# Partition count for the shared topic. Spark parallelism on Kafka is capped
# by partition count, NOT worker count, so this must be >= the max worker
# count in your scaling sweep (report targets 2 to 8).
KAFKA_PARTITIONS=8
# earliest = replay from topic start so the initial snapshot is captured
# even if Spark starts after producers. latest = live-only, miss snapshot.
STARTING_OFFSETS=earliest

# Parquet sink for per-book snapshots. Unset = no sink, metrics only (dev mode).
# Writes one subdir per batch_id so retries overwrite rather than double-count.
# SNAPSHOT_SINK_DIR=/tmp/lob_snapshots

# Which producers run_experiment.py should launch alongside Spark + Kafka.
# Comma-separated subset of: coinbase, binance, kraken
EXCHANGES=coinbase,binance,kraken

# Symbols per producer. Give each producer several so the per-symbol Kafka
# keying spreads the load across partitions. 12 symbols on 8 partitions
# gives a workable distribution for the 2-to-8-worker scaling sweep.
COINBASE_PRODUCTS=BTC-USD,ETH-USD,SOL-USD,LTC-USD
BINANCE_PRODUCTS=BTC-USDT,ETH-USDT,SOL-USDT,LTC-USDT
KRAKEN_PRODUCTS=BTC-USD,ETH-USD,SOL-USD,LTC-USD

# Coinbase WebSocket (public feed, no key required for level2)
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
COINBASE_REST_URL=https://api.exchange.coinbase.com

# Binance host selection. The main Binance domain geofences US traffic
# (HTTP 451), so the repo defaults to Binance.US. Override on Jetstream2 or
# any non-US egress if you want the canonical host and deeper liquidity.
BINANCE_WS_BASE=wss://stream.binance.us:9443/stream
BINANCE_REST_HOST=https://api.binance.us
# BINANCE_WS_BASE=wss://stream.binance.com:9443/stream
# BINANCE_REST_HOST=https://api.binance.com

# Kraken (public v2 feed, no key required)
KRAKEN_WS_URL=wss://ws.kraken.com/v2
KRAKEN_REST_URL=https://api.kraken.com
# Book depth per symbol on the WS v2 channel (10, 25, 100, 500, or 1000)
KRAKEN_DEPTH=10

# Jetstream2 SSH bootstrap (used by jetstream/ssh_run.py)
# Path to the private key matching the SSH key you uploaded to Jetstream2,
# and its passphrase if encrypted.
JETSTREAM_KEY_PATH=~/.ssh/id_rsa
JETSTREAM_KEY_PASSPHRASE=

# If you later add an authenticated Coinbase feed, put the secret here
# (never commit real values):
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
# COINBASE_PASSPHRASE=
