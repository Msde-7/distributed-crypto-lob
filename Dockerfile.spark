FROM apache/spark:3.5.3-python3

USER root
WORKDIR /app

RUN pip install --no-cache-dir kafka-python==2.0.2 websocket-client==1.8.0 requests==2.32.3

COPY normalizer.py order_book.py resync.py partitioning.py ./
COPY spark_order_book.py ./

ENV PYTHONUNBUFFERED=1

# Pull the Kafka connector at runtime; cached after first run per image.
CMD ["/opt/spark/bin/spark-submit", \
     "--packages", "org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.3", \
     "spark_order_book.py"]
